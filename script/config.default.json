{
	"mode": "debug",
	"arch": "loongarch64",
	"riscv64": {
		"compiler-prefix": "/usr/bin/riscv64-unknown-elf-",
		"additional-flags": {},
		"qemu": {
			"memory": {
				"size": "512m",
				"maxmem": "512m"
			},
			"attached": [
				"-d int",
				"-D qemu.log",
				"-rtc base=localtime,clock=host",
				"-drive file=sdcard-rv.img,if=none,format=raw,id=x0",
				"-device virtio-blk-device,drive=x0"
			]
		},
		"features": [
			"kernel-run-modules"
		],
		"logger": {},
		"linuxss": {
			"logger": {},
			"logger-disable-all": false
		},
		"logger-disable-all": false
	},
	"loongarch64": {
		"compiler-prefix": "/opt/gcc-13.2.0-loongarch64-linux-gnu/bin/loongarch64-linux-gnu-",
		"additional-flags": {},
		"qemu": {
			"memory": {
				"size": "512m",
				"maxmem": "512m"
			},
			"attached": [
				"-d int",
				"-D qemu.log",
				"-rtc base=localtime,clock=host",
				"-drive file=sdcard-la.img,if=none,format=raw,id=x0",
				"-device virtio-blk-pci,drive=x0"
			]
		},
		"features": [
			"kernel-run-modules"
		],
		"logger": {},
		"linuxss": {
			"logger": {},
			"logger-disable-all": false
		},
		"logger-disable-all": false
	}
}
