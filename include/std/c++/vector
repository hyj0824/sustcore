namespace std {
    namespace __vector_helper {
        template <class T>
        struct __is_integral : false_type {};
        template <>
        struct __is_integral<bool> : true_type {};
        template <>
        struct __is_integral<char> : true_type {};
        template <>
        struct __is_integral<signed char> : true_type {};
        template <>
        struct __is_integral<unsigned char> : true_type {};
        template <>
        struct __is_integral<short> : true_type {};
        template <>
        struct __is_integral<unsigned short> : true_type {};
        template <>
        struct __is_integral<int> : true_type {};
        template <>
        struct __is_integral<unsigned int> : true_type {};
        template <>
        struct __is_integral<long> : true_type {};
        template <>
        struct __is_integral<unsigned long> : true_type {};
        template <>
        struct __is_integral<long long> : true_type {};
        template <>
        struct __is_integral<unsigned long long> : true_type {};

        template <class T>
        inline constexpr bool __is_integral_v =
            __is_integral<remove_cv_t<T>>::value;
    }  // namespace __vector_helper

    template <class T, class Allocator = std::allocator<T>>
    class vector {
    public:
        using value_type             = T;
        using allocator_type         = Allocator;
        using size_type              = std::size_t;
        using difference_type        = std::ptrdiff_t;
        using reference              = value_type&;
        using const_reference        = const value_type&;
        using pointer                = typename allocator_traits<allocator_type>::pointer;
        using const_pointer          = typename allocator_traits<allocator_type>::const_pointer;
        using iterator               = pointer;
        using const_iterator         = const_pointer;

    private:
        static constexpr size_type U_constexpr_capacity = 64;

        union U_constexpr_storage_type {
            char D_dummy;
            value_type D_values[U_constexpr_capacity];

            constexpr U_constexpr_storage_type() noexcept : D_dummy() {}
            constexpr ~U_constexpr_storage_type() {}
        };

        pointer D_data       = nullptr;
        size_type D_size     = 0;
        size_type D_capacity = 0;
        bool D_constexpr_view = false;
        U_constexpr_storage_type D_constexpr_storage;
        allocator_type D_alloc;

        [[nodiscard]]
        constexpr size_type U_next_capacity(size_type required) const noexcept {
            size_type next = D_capacity == 0 ? size_type(1) : D_capacity * 2;
            return next < required ? required : next;
        }

        [[nodiscard]]
        constexpr bool U_over_max(size_type count) const noexcept {
            return count > max_size();
        }

        [[nodiscard]]
        constexpr bool U_add_overflows(size_type a, size_type b) const noexcept {
            return a > max_size() - b;
        }

        constexpr pointer U_allocate(size_type count) {
            if (count == 0) {
                return nullptr;
            }
            return allocator_traits<allocator_type>::allocate(D_alloc, count);
        }

        constexpr result_nt<pointer> U_allocate_nt(size_type count) noexcept {
            if (count == 0) {
                return pointer(nullptr);
            }
            if (U_over_max(count)) {
                return {unexpect, error_type::OVERFLOW_ERROR};
            }
            pointer data = allocator_traits<allocator_type>::allocate(D_alloc, count);
            if (data == nullptr) {
                return {unexpect, error_type::NULLPTR};
            }
            return data;
        }

        constexpr void U_deallocate(pointer data, size_type capacity) noexcept {
            if (data != nullptr) {
                allocator_traits<allocator_type>::deallocate(D_alloc, data, capacity);
            }
        }

        template <class... Args>
        constexpr void U_construct(pointer where, Args&&... args) {
            allocator_traits<allocator_type>::construct(
                D_alloc, where, std::forward<Args>(args)...);
        }

        constexpr void U_destroy(pointer where) noexcept {
            D_alloc.destroy(where);
        }

        constexpr void U_destroy_range(pointer first, pointer last) noexcept {
            while (first != last) {
                U_destroy(first);
                ++first;
            }
        }

        template <class InputIt>
        [[nodiscard]]
        constexpr size_type U_count_range(InputIt first, InputIt last) const noexcept {
            size_type count = 0;
            while (first != last) {
                ++first;
                ++count;
            }
            return count;
        }

        [[nodiscard]]
        constexpr pointer U_end_ptr() noexcept {
            return D_data == nullptr ? nullptr : D_data + D_size;
        }

        [[nodiscard]]
        constexpr const_pointer U_end_ptr() const noexcept {
            return D_data == nullptr ? nullptr : D_data + D_size;
        }

        constexpr void U_reset() noexcept {
            if (D_constexpr_view) {
                D_data           = nullptr;
                D_size           = 0;
                D_capacity       = 0;
                D_constexpr_view = false;
                return;
            }
            U_destroy_range(D_data, U_end_ptr());
            U_deallocate(D_data, D_capacity);
            D_data     = nullptr;
            D_size     = 0;
            D_capacity = 0;
        }

        constexpr result_nt<void> U_reallocate_nt(size_type new_capacity) noexcept {
            auto allocated = U_allocate_nt(new_capacity);
            if (!allocated) {
                return {unexpect, allocated.error()};
            }

            pointer new_data = allocated.value();
            bool was_constexpr_view = D_constexpr_view;
            size_type i      = 0;
            for (; i < D_size; ++i) {
                U_construct(new_data + i, std::move(D_data[i]));
            }

            if (!was_constexpr_view) {
                U_destroy_range(D_data, U_end_ptr());
                U_deallocate(D_data, D_capacity);
            }
            D_data           = new_data;
            D_capacity       = new_capacity;
            D_constexpr_view = false;
            return {};
        }

        constexpr void U_reallocate(size_type new_capacity) {
            if (U_over_max(new_capacity)) {
                _THROW(length_error("vector::reserve: new capacity too large"));
            }
            pointer new_data = U_allocate(new_capacity);
            if (new_capacity != 0 && new_data == nullptr) {
                _THROW(bad_alloc());
            }

            size_type i = 0;
            bool was_constexpr_view = D_constexpr_view;
            for (; i < D_size; ++i) {
                U_construct(new_data + i, std::move(D_data[i]));
            }

            if (!was_constexpr_view) {
                U_destroy_range(D_data, U_end_ptr());
                U_deallocate(D_data, D_capacity);
            }
            D_data           = new_data;
            D_capacity       = new_capacity;
            D_constexpr_view = false;
        }

        constexpr result_nt<void> U_ensure_capacity_nt(size_type required) noexcept {
            if (required <= D_capacity) {
                return {};
            }
            if (U_over_max(required)) {
                return {unexpect, error_type::OVERFLOW_ERROR};
            }
            return U_reallocate_nt(U_next_capacity(required));
        }

        constexpr void U_ensure_capacity(size_type required) {
            if (required <= D_capacity) {
                return;
            }
            if (U_over_max(required)) {
                _THROW(length_error("vector: capacity too large"));
            }
            U_reallocate(U_next_capacity(required));
        }

        constexpr void U_fill_construct(size_type count, const_reference value) {
            U_ensure_capacity(count);
            for (; D_size < count; ++D_size) {
                U_construct(D_data + D_size, value);
            }
        }

        constexpr result_nt<void> U_fill_construct_nt(
            size_type count, const_reference value) noexcept {
            auto reserved = U_ensure_capacity_nt(count);
            if (!reserved) {
                return {unexpect, reserved.error()};
            }
            for (; D_size < count; ++D_size) {
                U_construct(D_data + D_size, value);
            }
            return {};
        }

        template <class InputIt>
        constexpr void U_range_construct(InputIt first, InputIt last) {
            size_type count = U_count_range(first, last);
            U_ensure_capacity(count);
            for (; first != last; ++first) {
                U_construct(D_data + D_size, *first);
                ++D_size;
            }
        }

        template <class InputIt>
        constexpr result_nt<void> U_range_construct_nt(
            InputIt first, InputIt last) noexcept {
            size_type count = U_count_range(first, last);
            auto reserved   = U_ensure_capacity_nt(count);
            if (!reserved) {
                return {unexpect, reserved.error()};
            }
            for (; first != last; ++first) {
                U_construct(D_data + D_size, *first);
                ++D_size;
            }
            return {};
        }

        [[nodiscard]]
        constexpr size_type U_index_of(const_iterator pos) const noexcept {
            if (D_data == nullptr && pos == nullptr) {
                return 0;
            }
            return static_cast<size_type>(pos - cbegin());
        }

    public:
        constexpr vector() noexcept = default;

        constexpr explicit vector(const allocator_type& alloc) noexcept
            : D_alloc(alloc) {}

        EXCEPTION_DEPRECATED
        constexpr explicit vector(size_type count, const allocator_type& alloc = allocator_type())
            : D_alloc(alloc) {
            resize(count);
        }

        EXCEPTION_DEPRECATED
        constexpr vector(size_type count, const_reference value,
               const allocator_type& alloc = allocator_type())
            : D_alloc(alloc) {
            U_fill_construct(count, value);
        }

        template <class InputIt>
            requires (!__vector_helper::__is_integral_v<InputIt>)
        EXCEPTION_DEPRECATED
        constexpr vector(InputIt first, InputIt last,
               const allocator_type& alloc = allocator_type())
            : D_alloc(alloc) {
            U_range_construct(first, last);
        }

        EXCEPTION_DEPRECATED
        constexpr vector(std::initializer_list<value_type> init,
               const allocator_type& alloc = allocator_type())
            : D_alloc(alloc) {
            if consteval {
                if (init.size() <= U_constexpr_capacity) {
                    D_data           = D_constexpr_storage.D_values;
                    D_size           = init.size();
                    D_capacity       = U_constexpr_capacity;
                    D_constexpr_view = true;
                    for (size_type i = 0; i < init.size(); ++i) {
                        ::new (&D_constexpr_storage.D_values[i])
                            value_type(init.begin()[i]);
                    }
                } else {
                    U_range_construct(init.begin(), init.end());
                }
            } else {
                U_range_construct(init.begin(), init.end());
            }
        }

        EXCEPTION_DEPRECATED
        constexpr vector(const vector& other)
            : D_alloc(other.D_alloc) {
            U_range_construct(other.begin(), other.end());
        }

        EXCEPTION_DEPRECATED
        constexpr vector(const vector& other, const allocator_type& alloc)
            : D_alloc(alloc) {
            U_range_construct(other.begin(), other.end());
        }

        constexpr vector(vector&& other) noexcept
            : D_data(other.D_data),
              D_size(other.D_size),
              D_capacity(other.D_capacity),
              D_constexpr_view(other.D_constexpr_view),
              D_alloc(std::move(other.D_alloc)) {
            if (other.D_constexpr_view) {
                D_data     = D_constexpr_storage.D_values;
                D_capacity = U_constexpr_capacity;
                for (size_type i = 0; i < D_size; ++i) {
                    ::new (&D_constexpr_storage.D_values[i])
                        value_type(std::move(other.D_data[i]));
                }
            }
            other.D_data     = nullptr;
            other.D_size     = 0;
            other.D_capacity = 0;
            other.D_constexpr_view = false;
        }

        EXCEPTION_DEPRECATED
        constexpr vector(vector&& other, const allocator_type& alloc)
            : D_alloc(alloc) {
            if (D_alloc == other.D_alloc) {
                D_data           = other.D_data;
                D_size           = other.D_size;
                D_capacity       = other.D_capacity;
                D_constexpr_view = other.D_constexpr_view;
                if (other.D_constexpr_view) {
                    D_data     = D_constexpr_storage.D_values;
                    D_capacity = U_constexpr_capacity;
                    for (size_type i = 0; i < D_size; ++i) {
                        ::new (&D_constexpr_storage.D_values[i])
                            value_type(std::move(other.D_data[i]));
                    }
                }
                other.D_data     = nullptr;
                other.D_size     = 0;
                other.D_capacity = 0;
                other.D_constexpr_view = false;
            } else {
                U_range_construct(other.begin(), other.end());
                other.clear();
            }
        }

        constexpr ~vector() {
            U_reset();
        }

        EXCEPTION_DEPRECATED
        constexpr vector& operator=(const vector& other) {
            if (this != &other) {
                vector temp(other);
                swap(temp);
            }
            return *this;
        }

        constexpr vector& operator=(vector&& other) noexcept {
            if (this != &other) {
                U_reset();
                D_data           = other.D_data;
                D_size           = other.D_size;
                D_capacity       = other.D_capacity;
                D_alloc          = std::move(other.D_alloc);
                D_constexpr_view = other.D_constexpr_view;
                if (other.D_constexpr_view) {
                    D_data     = D_constexpr_storage.D_values;
                    D_capacity = U_constexpr_capacity;
                    for (size_type i = 0; i < D_size; ++i) {
                        ::new (&D_constexpr_storage.D_values[i])
                            value_type(std::move(other.D_data[i]));
                    }
                }
                other.D_data     = nullptr;
                other.D_size     = 0;
                other.D_capacity = 0;
                other.D_constexpr_view = false;
            }
            return *this;
        }

        EXCEPTION_DEPRECATED
        constexpr vector& operator=(std::initializer_list<value_type> ilist) {
            assign(ilist);
            return *this;
        }

        EXCEPTION_DEPRECATED
        constexpr void assign(size_type count, const_reference value) {
            clear();
            U_fill_construct(count, value);
        }

        constexpr result_nt<void> assign_nt(size_type count,
                                            const_reference value) noexcept {
            vector temp(D_alloc);
            auto built = temp.U_fill_construct_nt(count, value);
            if (!built) {
                return {unexpect, built.error()};
            }
            swap(temp);
            return {};
        }

        template <class InputIt>
            requires (!__vector_helper::__is_integral_v<InputIt>)
        EXCEPTION_DEPRECATED
        constexpr void assign(InputIt first, InputIt last) {
            clear();
            U_range_construct(first, last);
        }

        template <class InputIt>
            requires (!__vector_helper::__is_integral_v<InputIt>)
        constexpr result_nt<void> assign_nt(InputIt first,
                                            InputIt last) noexcept {
            vector temp(D_alloc);
            auto built = temp.U_range_construct_nt(first, last);
            if (!built) {
                return {unexpect, built.error()};
            }
            swap(temp);
            return {};
        }

        EXCEPTION_DEPRECATED
        constexpr void assign(std::initializer_list<value_type> ilist) {
            assign(ilist.begin(), ilist.end());
        }

        constexpr result_nt<void> assign_nt(
            std::initializer_list<value_type> ilist) noexcept {
            return assign_nt(ilist.begin(), ilist.end());
        }

        [[nodiscard]]
        constexpr allocator_type get_allocator() const noexcept {
            return D_alloc;
        }

        [[nodiscard]]
        constexpr reference at(size_type pos) {
            if (pos >= D_size) {
                _THROW(out_of_range("vector::at: pos out of range"));
            }
            return D_data[pos];
        }

        [[nodiscard]]
        constexpr const_reference at(size_type pos) const {
            if (pos >= D_size) {
                _THROW(out_of_range("vector::at: pos out of range"));
            }
            return D_data[pos];
        }

        [[nodiscard]]
        constexpr result_nt<pointer> at_nt(size_type pos) noexcept {
            if (pos >= D_size) {
                return {unexpect, error_type::OUT_OF_RANGE};
            }
            return &D_data[pos];
        }

        [[nodiscard]]
        constexpr result_nt<const_pointer> at_nt(size_type pos) const noexcept {
            if (pos >= D_size) {
                return {unexpect, error_type::OUT_OF_RANGE};
            }
            return &D_data[pos];
        }

        [[nodiscard]]
        constexpr reference operator[](size_type pos) noexcept {
            return D_data[pos];
        }

        [[nodiscard]]
        constexpr const_reference operator[](size_type pos) const noexcept {
            return D_data[pos];
        }

        [[nodiscard]]
        constexpr reference front() noexcept {
            return D_data[0];
        }

        [[nodiscard]]
        constexpr const_reference front() const noexcept {
            return D_data[0];
        }

        [[nodiscard]]
        constexpr reference back() noexcept {
            return D_data[D_size - 1];
        }

        [[nodiscard]]
        constexpr const_reference back() const noexcept {
            return D_data[D_size - 1];
        }

        [[nodiscard]]
        constexpr pointer data() noexcept {
            return D_data;
        }

        [[nodiscard]]
        constexpr const_pointer data() const noexcept {
            return D_data;
        }

        [[nodiscard]]
        constexpr iterator begin() noexcept {
            return D_data;
        }

        [[nodiscard]]
        constexpr const_iterator begin() const noexcept {
            return D_data;
        }

        [[nodiscard]]
        constexpr const_iterator cbegin() const noexcept {
            return D_data;
        }

        [[nodiscard]]
        constexpr iterator end() noexcept {
            return U_end_ptr();
        }

        [[nodiscard]]
        constexpr const_iterator end() const noexcept {
            return U_end_ptr();
        }

        [[nodiscard]]
        constexpr const_iterator cend() const noexcept {
            return U_end_ptr();
        }

        [[nodiscard]]
        constexpr bool empty() const noexcept {
            return D_size == 0;
        }

        [[nodiscard]]
        constexpr size_type size() const noexcept {
            return D_size;
        }

        [[nodiscard]]
        constexpr size_type max_size() const noexcept {
            return numeric_limits<size_type>::max() / sizeof(value_type);
        }

        EXCEPTION_DEPRECATED
        constexpr void reserve(size_type new_cap) {
            if (new_cap > D_capacity) {
                U_reallocate(new_cap);
            }
        }

        constexpr result_nt<void> reserve_nt(size_type new_cap) noexcept {
            if (new_cap <= D_capacity) {
                return {};
            }
            return U_reallocate_nt(new_cap);
        }

        [[nodiscard]]
        constexpr size_type capacity() const noexcept {
            return D_capacity;
        }

        EXCEPTION_DEPRECATED
        constexpr void shrink_to_fit() {
            if (D_size < D_capacity) {
                U_reallocate(D_size);
            }
        }

        constexpr result_nt<void> shrink_to_fit_nt() noexcept {
            if (D_size >= D_capacity) {
                return {};
            }
            return U_reallocate_nt(D_size);
        }

        constexpr void clear() noexcept {
            U_destroy_range(D_data, U_end_ptr());
            D_size = 0;
        }

        EXCEPTION_DEPRECATED
        constexpr iterator insert(const_iterator pos, const_reference value) {
            return emplace(pos, value);
        }

        constexpr result_nt<iterator> insert_nt(
            const_iterator pos, const_reference value) noexcept {
            return emplace_nt(pos, value);
        }

        EXCEPTION_DEPRECATED
        constexpr iterator insert(const_iterator pos, value_type&& value) {
            return emplace(pos, std::move(value));
        }

        constexpr result_nt<iterator> insert_nt(
            const_iterator pos, value_type&& value) noexcept {
            return emplace_nt(pos, std::move(value));
        }

        EXCEPTION_DEPRECATED
        constexpr iterator insert(const_iterator pos, size_type count,
                                  const_reference value) {
            size_type index = U_index_of(pos);
            if (index > D_size) {
                _THROW(out_of_range("vector::insert: pos out of range"));
            }
            if (count == 0) {
                return begin() + index;
            }
            if (U_add_overflows(D_size, count)) {
                _THROW(length_error("vector::insert: size too large"));
            }
            U_ensure_capacity(D_size + count);

            for (size_type i = D_size; i > index; --i) {
                U_construct(D_data + i + count - 1, std::move(D_data[i - 1]));
                U_destroy(D_data + i - 1);
            }
            for (size_type i = 0; i < count; ++i) {
                U_construct(D_data + index + i, value);
            }
            D_size += count;
            return begin() + index;
        }

        constexpr result_nt<iterator> insert_nt(
            const_iterator pos, size_type count,
            const_reference value) noexcept {
            size_type index = U_index_of(pos);
            if (index > D_size) {
                return {unexpect, error_type::OUT_OF_RANGE};
            }
            if (count == 0) {
                return begin() + index;
            }
            if (U_add_overflows(D_size, count)) {
                return {unexpect, error_type::OVERFLOW_ERROR};
            }
            auto reserved = U_ensure_capacity_nt(D_size + count);
            if (!reserved) {
                return {unexpect, reserved.error()};
            }

            for (size_type i = D_size; i > index; --i) {
                U_construct(D_data + i + count - 1, std::move(D_data[i - 1]));
                U_destroy(D_data + i - 1);
            }
            for (size_type i = 0; i < count; ++i) {
                U_construct(D_data + index + i, value);
            }
            D_size += count;
            return begin() + index;
        }

        template <class InputIt>
            requires (!__vector_helper::__is_integral_v<InputIt>)
        EXCEPTION_DEPRECATED
        constexpr iterator insert(const_iterator pos, InputIt first,
                                  InputIt last) {
            size_type index = U_index_of(pos);
            if (index > D_size) {
                _THROW(out_of_range("vector::insert: pos out of range"));
            }
            vector temp(first, last, D_alloc);
            if (U_add_overflows(D_size, temp.size())) {
                _THROW(length_error("vector::insert: size too large"));
            }
            U_ensure_capacity(D_size + temp.size());
            size_type count = temp.size();
            for (size_type i = D_size; i > index; --i) {
                U_construct(D_data + i + count - 1, std::move(D_data[i - 1]));
                U_destroy(D_data + i - 1);
            }
            for (size_type i = 0; i < count; ++i) {
                U_construct(D_data + index + i, temp[i]);
            }
            D_size += count;
            return begin() + index;
        }

        template <class InputIt>
            requires (!__vector_helper::__is_integral_v<InputIt>)
        constexpr result_nt<iterator> insert_nt(const_iterator pos,
                                                InputIt first,
                                                InputIt last) noexcept {
            size_type index = U_index_of(pos);
            if (index > D_size) {
                return {unexpect, error_type::OUT_OF_RANGE};
            }
            vector temp(D_alloc);
            auto built = temp.assign_nt(first, last);
            if (!built) {
                return {unexpect, built.error()};
            }
            if (U_add_overflows(D_size, temp.size())) {
                return {unexpect, error_type::OVERFLOW_ERROR};
            }
            auto reserved = U_ensure_capacity_nt(D_size + temp.size());
            if (!reserved) {
                return {unexpect, reserved.error()};
            }
            size_type count = temp.size();
            for (size_type i = D_size; i > index; --i) {
                U_construct(D_data + i + count - 1, std::move(D_data[i - 1]));
                U_destroy(D_data + i - 1);
            }
            for (size_type i = 0; i < count; ++i) {
                U_construct(D_data + index + i, temp[i]);
            }
            D_size += count;
            return begin() + index;
        }

        EXCEPTION_DEPRECATED
        constexpr iterator insert(const_iterator pos,
                                  std::initializer_list<value_type> ilist) {
            return insert(pos, ilist.begin(), ilist.end());
        }

        constexpr result_nt<iterator> insert_nt(
            const_iterator pos,
            std::initializer_list<value_type> ilist) noexcept {
            return insert_nt(pos, ilist.begin(), ilist.end());
