#pragma once

#include <functional>
#include <iterator>
namespace std {
    /**
     * @brief 对 [begin, sort) 进行排序
     *
     * @tparam T Data Type
     * @tparam Compare 比较函数类型
     * @param begin 起始
     * @param end 结束
     * @param comp 比较函数
     */
    template <typename RandomIt, typename Compare>
    void sort(RandomIt begin, RandomIt end, Compare comp) {
        // 此处采取简单的插入排序
        for (RandomIt i = begin + 1; i < end; i++) {
            auto key   = *i;
            RandomIt j = i - 1;

            while (j >= begin && comp(key, *j)) {
                *(j + 1) = *j;
                j--;
            }
            *(j + 1) = key;
        }
    }

    /**
     * @brief 对 [begin, sort) 进行排序
     *
     * @tparam T Data Type
     * @tparam Compare 比较函数类型
     * @param begin 起始
     * @param end 结束
     * @param comp 比较函数
     */
    template <typename RandomIt>
    void sort(RandomIt begin, RandomIt end) {
        using value_type = typename iterator_traits<RandomIt>::value_type;
        return sort(begin, end, std::less<value_type>());
    }

    /**
     * @brief 在区间中查找满足谓词的首个元素.
     *
     * @tparam It 迭代器类型.
     * @tparam Pred 谓词类型.
     * @param begin 起始迭代器.
     * @param end 结束迭代器.
     * @param pred 判定谓词.
     * @return It 指向首个满足条件元素的迭代器, 若不存在则返回 `end`.
     */
    template <typename It, typename Pred>
    It find_if(It begin, It end, Pred pred) {
        for (It it = begin; it != end; ++it) {
            if (pred(*it)) {
                return it;
            }
        }
        return end;
    }

    /**
     * @brief 在区间中查找与给定值相等的首个元素.
     *
     * @tparam It 迭代器类型.
     * @tparam T 值类型.
     * @param begin 起始迭代器.
     * @param end 结束迭代器.
     * @param value 目标值.
     * @return It 指向首个匹配元素的迭代器, 若不存在则返回 `end`.
     */
    template <typename It, typename T>
    It find(It begin, It end, const T& value) {
        return find_if(begin, end,
                       [&value](const auto& elem) { return elem == value; });
    }

    /**
     * @brief 移除区间中所有满足谓词的元素.
     *
     * @tparam It 迭代器类型.
     * @tparam Pred 谓词类型.
     * @param begin 起始迭代器.
     * @param end 结束迭代器.
     * @param pred 判定谓词.
     * @return It 逻辑新区间的尾后迭代器.
     */
    template <typename It, typename Pred>
    It remove_if(It begin, It end, Pred pred) {
        It write = begin;
        for (It read = begin; read != end; ++read) {
            if (!pred(*read)) {
                *write = *read;
                ++write;
            }
        }
        return write;
    }

    /**
     * @brief 移除区间中所有与给定值相等的元素.
     *
     * @tparam It 迭代器类型.
     * @tparam T 值类型.
     * @param begin 起始迭代器.
     * @param end 结束迭代器.
     * @param value 目标值.
     * @return It 逻辑新区间的尾后迭代器.
     */
    template <typename It, typename T>
    It remove(It begin, It end, const T& value) {
        return remove_if(begin, end,
                         [&value](const auto& elem) { return elem == value; });
    }

    /**
     * @brief 移除区间中按谓词视为重复的相邻元素.
     *
     * @tparam ForwardIt 前向迭代器类型.
     * @tparam BinaryPred 二元谓词类型.
     * @param first 起始迭代器.
     * @param last 结束迭代器.
     * @param pred 相等性判定谓词.
     * @return ForwardIt 逻辑新区间的尾后迭代器.
     */
    template <typename ForwardIt, typename BinaryPred>
    ForwardIt unique(ForwardIt first, ForwardIt last, BinaryPred pred) {
        if (first == last)
            return last;

        ForwardIt result = first;
        while (++first != last) {
            if (!pred(*result, *first)) {  // 使用谓词判定是否相等
                ++result;
                *result = std::move(*first);
            }
        }
        return ++result;
    }

    /**
     * @brief 移除区间中相邻的重复元素.
     *
     * @tparam ForwardIt 前向迭代器类型.
     * @param first 起始迭代器.
     * @param last 结束迭代器.
     * @return ForwardIt 逻辑新区间的尾后迭代器.
     */
    template <typename ForwardIt>
    ForwardIt unique(ForwardIt first, ForwardIt last) {
        using value_type = typename iterator_traits<ForwardIt>::value_type;
        return unique(first, last, std::equal_to<value_type>());
    }

    /**
     * @brief 返回两个值中的较小者.
     *
     * @tparam T 值类型.
     * @param a 第一个值.
     * @param b 第二个值.
     * @return constexpr const T& 较小值的引用.
     */
    template <typename T>
    constexpr const T& min(const T& a, const T& b) {
        return (a < b) ? a : b;
    }

    /**
     * @brief 返回两个值中的较大者.
     *
     * @tparam T 值类型.
     * @param a 第一个值.
     * @param b 第二个值.
     * @return constexpr const T& 较大值的引用.
     */
    template <typename T>
    constexpr const T& max(const T& a, const T& b) {
        return (a > b) ? a : b;
    }

    /**
     * @brief 计算数值的绝对值.
     *
     * @tparam T 数值类型.
     * @param value 输入值.
     * @return constexpr T 绝对值结果.
     */
    template <typename T>
    constexpr T abs(const T& value) {
        return (value < 0) ? -value : value;
    }

    /**
     * @brief 将值钳制在给定闭区间内.
     *
     * @tparam T 值类型.
     * @param value 输入值.
     * @param low 下界.
     * @param high 上界.
     * @return constexpr T 钳制后的结果.
     */
    template <typename T>
    constexpr T clamp(const T& value, const T& low, const T& high) {
        return max(low, min(value, high));
    }
}  // namespace std
