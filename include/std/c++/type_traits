    // reference_wrapper
    template <typename T>
    class reference_wrapper {
    private:
        T* __ptr;

    public:
        using type = T;

        constexpr explicit reference_wrapper(T& ref) noexcept : __ptr(&ref) {}
        constexpr reference_wrapper(T&&) = delete;

        constexpr reference_wrapper(const reference_wrapper&) noexcept =
            default;
        constexpr reference_wrapper& operator=(
            const reference_wrapper&) noexcept = default;

        constexpr operator T&() const noexcept {
            return *__ptr;
        }

        constexpr T& get() const noexcept {
            return *__ptr;
        }

        template <typename... Args>
        constexpr auto operator()(Args&&... args) const
            -> decltype((*__ptr)(forward<Args>(args)...)) {
            return (*__ptr)(forward<Args>(args)...);
        }
    };

    namespace detail {
        // pointer-to-member function, reference_wrapper as object
        template <
            typename F, typename T, typename... Args,
            typename = enable_if_t<is_member_function_pointer_v<decay_t<F>>>>
        constexpr auto invoke_impl(F&& f, reference_wrapper<T> t,
                                   Args&&... args)
            -> decltype((t.get().*forward<F>(f))(forward<Args>(args)...)) {
            return (t.get().*forward<F>(f))(forward<Args>(args)...);
        }

        // pointer-to-member function, object instance (not pointer)
        template <
            typename F, typename T1, typename... Args,
            typename = enable_if_t<is_member_function_pointer_v<decay_t<F>>>>
        constexpr auto invoke_impl(F&& f, T1&& t1, Args&&... args)
            -> decltype((forward<T1>(t1).*
                         forward<F>(f))(forward<Args>(args)...)) {
            return (forward<T1>(t1).*forward<F>(f))(forward<Args>(args)...);
        }

        // pointer-to-member function, pointer to object
        template <
            typename F, typename T1, typename... Args,
            typename = enable_if_t<is_member_function_pointer_v<decay_t<F>>>>
        constexpr auto invoke_impl(F&& f, T1* t1, Args&&... args)
            -> decltype((t1->*forward<F>(f))(forward<Args>(args)...)) {
            return (t1->*forward<F>(f))(forward<Args>(args)...);
        }

        // pointer-to-data member, reference_wrapper as object
        template <
            typename F, typename T,
            typename = enable_if_t<is_member_object_pointer_v<decay_t<F>>>>
        constexpr auto invoke_impl(F&& f, reference_wrapper<T> t)
            -> decltype(t.get().*forward<F>(f)) {
            return t.get().*forward<F>(f);
        }

        // pointer-to-data member, object instance (not pointer)
        template <
            typename F, typename T1,
            typename = enable_if_t<is_member_object_pointer_v<decay_t<F>>>>
        constexpr auto invoke_impl(F&& f, T1&& t1) -> decltype(forward<T1>(t1).*
                                                               forward<F>(f)) {
            return forward<T1>(t1).*forward<F>(f);
        }

        // pointer-to-data member, pointer to object
        template <
            typename F, typename T1,
            typename = enable_if_t<is_member_object_pointer_v<decay_t<F>>>>
        constexpr auto invoke_impl(F&& f,
                                   T1* t1) -> decltype(t1->*forward<F>(f)) {
            return t1->*forward<F>(f);
        }

        // general callable (non-member-pointer)
        template <typename F, typename... Args>
        constexpr auto invoke_impl(F&& f, Args&&... args)
            -> decltype(forward<F>(f)(forward<Args>(args)...)) {
            return forward<F>(f)(forward<Args>(args)...);
        }
    }  // namespace detail

    // invoke_result
    template <typename _Fp, typename... _Args>
    struct invoke_result {
        using type =
            decltype(detail::invoke_impl(declval<_Fp>(), declval<_Args>()...));
    };

    template <typename _Fp, typename... _Args>
    using invoke_result_t = typename invoke_result<_Fp, _Args...>::type;

    // 探测某个表达式是否有效(无效)
    template <typename _Default, template <typename...> class _Operation,
              typename... _Args>
    struct __detected_or {
        using type          = _Default;
        using __is_detected = false_type;
    };

    // 探测某个表达式是否有效(有效)
    template <typename _Default, template <typename...> class _Operation,
              typename... _Args>
        requires requires { typename _Operation<_Args...>; }
    struct __detected_or<_Default, _Operation, _Args...> {
        using type          = _Operation<_Args...>;
        using __is_detected = true_type;
    };

    template <typename _Default, template <typename...> class _Operation,
              typename... _Args>
    using __detected_or_t =
        typename __detected_or<_Default, _Operation, _Args...>::type;

