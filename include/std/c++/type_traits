    // is_member_pointer
    template <typename _Tp>
    struct is_member_pointer : public false_type {};
    template <typename _Tp, typename _Class>
    struct is_member_pointer<_Tp _Class::*> : public true_type {};
    template <typename _Tp, typename _Class>
    struct is_member_pointer<_Tp _Class::* const> : public true_type {};
    template <typename _Tp, typename _Class>
    struct is_member_pointer<_Tp _Class::* volatile> : public true_type {};
    template <typename _Tp, typename _Class>
    struct is_member_pointer<_Tp _Class::* const volatile> : public true_type {
    };

    // is_member_function_pointer
    template <typename _Tp>
    struct is_member_function_pointer : public false_type {};
    template <typename _Tp, typename _Class>
    struct is_member_function_pointer<_Tp _Class::*>
        : public is_function<_Tp> {};
    template <typename _Tp, typename _Class>
    struct is_member_function_pointer<_Tp _Class::* const>
        : public is_member_function_pointer<_Tp _Class::*> {};
    template <typename _Tp, typename _Class>
    struct is_member_function_pointer<_Tp _Class::* volatile>
        : public is_member_function_pointer<_Tp _Class::*> {};
    template <typename _Tp, typename _Class>
    struct is_member_function_pointer<_Tp _Class::* const volatile>
        : public is_member_function_pointer<_Tp _Class::*> {};

