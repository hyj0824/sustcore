#pragma once

#include <cassert>
#include <compare>
#include <cstddef>
#include <functional>
#include <nt/errors.h>
#include <stdexcept>
#include <type_traits>
#include <utility>

namespace std {
    template <class T>
    struct tuple_size;

    template <std::size_t I, class T>
    struct tuple_element;

    namespace __array_helper {
        template <class T, std::size_t N>
        struct __array_storage {
            T elems[N];

            [[nodiscard]]
            constexpr T* data() noexcept {
                return elems;
            }

            [[nodiscard]]
            constexpr const T* data() const noexcept {
                return elems;
            }

            [[nodiscard]]
            constexpr T& ref(std::size_t pos) noexcept {
                return elems[pos];
            }

            [[nodiscard]]
            constexpr const T& ref(std::size_t pos) const noexcept {
                return elems[pos];
            }
        };

        template <class T>
        struct __array_storage<T, 0> {
            [[nodiscard]]
            constexpr T* data() noexcept {
                return nullptr;
            }

            [[nodiscard]]
            constexpr const T* data() const noexcept {
                return nullptr;
            }

            [[nodiscard]]
            constexpr T& ref(std::size_t pos [[maybe_unused]]) noexcept {
                assert(false);
                return *static_cast<T*>(nullptr);
            }

            [[nodiscard]]
            constexpr const T& ref(
                std::size_t pos [[maybe_unused]]) const noexcept {
                assert(false);
                return *static_cast<const T*>(nullptr);
            }
        };
    }  // namespace __array_helper

    template <class T, std::size_t N>
    struct array {
        using value_type      = T;
        using size_type       = std::size_t;
        using difference_type = std::ptrdiff_t;
        using reference       = value_type&;
        using const_reference = const value_type&;
        using pointer         = value_type*;
        using const_pointer   = const value_type*;
        using iterator        = pointer;
        using const_iterator  = const_pointer;

        __array_helper::__array_storage<T, N> D_elems;

        [[nodiscard]]
        constexpr iterator begin() noexcept {
            return data();
        }

        [[nodiscard]]
        constexpr const_iterator begin() const noexcept {
            return data();
        }

        [[nodiscard]]
        constexpr const_iterator cbegin() const noexcept {
            return data();
        }

        [[nodiscard]]
        constexpr iterator end() noexcept {
            if constexpr (N == 0) {
                return data();
            }
            return data() + N;
        }

        [[nodiscard]]
        constexpr const_iterator end() const noexcept {
            if constexpr (N == 0) {
                return data();
            }
            return data() + N;
        }

        [[nodiscard]]
        constexpr const_iterator cend() const noexcept {
            if constexpr (N == 0) {
                return data();
            }
            return data() + N;
        }

        [[nodiscard]]
        constexpr size_type size() const noexcept {
            return N;
        }

        [[nodiscard]]
        constexpr size_type max_size() const noexcept {
            return N;
        }

        [[nodiscard]]
        constexpr bool empty() const noexcept {
            return N == 0;
        }

        [[nodiscard]]
        constexpr reference operator[](size_type pos) noexcept {
            return D_elems.ref(pos);
        }

        [[nodiscard]]
        constexpr const_reference operator[](size_type pos) const noexcept {
            return D_elems.ref(pos);
        }

        [[nodiscard]]
        EXCEPTION_DEPRECATED
        constexpr reference at(size_type pos) {
            if (pos >= N) {
                _THROW(out_of_range("array::at: pos out of range"));
            }
            return D_elems.ref(pos);
        }

        [[nodiscard]]
        EXCEPTION_DEPRECATED
        constexpr const_reference at(size_type pos) const {
            if (pos >= N) {
                _THROW(out_of_range("array::at: pos out of range"));
            }
            return D_elems.ref(pos);
        }

        [[nodiscard]]
        constexpr result_nt<pointer> at_nt(size_type pos) noexcept {
            if (pos >= N) {
                return {unexpect, error_type::OUT_OF_RANGE};
            }
            return &D_elems.ref(pos);
        }

        [[nodiscard]]
        constexpr result_nt<const_pointer> at_nt(size_type pos) const noexcept {
            if (pos >= N) {
                return {unexpect, error_type::OUT_OF_RANGE};
            }
            return &D_elems.ref(pos);
        }

        [[nodiscard]]
        constexpr reference front() noexcept {
            assert(N > 0);
            return D_elems.ref(0);
        }

        [[nodiscard]]
        constexpr const_reference front() const noexcept {
            assert(N > 0);
            return D_elems.ref(0);
        }

        [[nodiscard]]
        constexpr reference back() noexcept {
            assert(N > 0);
            return D_elems.ref(N - 1);
        }

        [[nodiscard]]
        constexpr const_reference back() const noexcept {
            assert(N > 0);
            return D_elems.ref(N - 1);
        }

        [[nodiscard]]
        constexpr pointer data() noexcept {
            return D_elems.data();
        }

        [[nodiscard]]
        constexpr const_pointer data() const noexcept {
            return D_elems.data();
        }

        constexpr void fill(const T& value) {
            for (size_type i = 0; i < N; ++i) {
                D_elems.ref(i) = value;
            }
        }

        constexpr void swap(array& other) {
            for (size_type i = 0; i < N; ++i) {
                std::swap(D_elems.ref(i), other.D_elems.ref(i));
            }
        }
    };

    template <class T, class... U>
        requires (is_same_v<T, U> && ...)
    array(T, U...) -> array<T, 1 + sizeof...(U)>;

    template <class T, std::size_t N>
    struct tuple_size<array<T, N>> : integral_constant<std::size_t, N> {};

    template <std::size_t I, class T, std::size_t N>
    struct tuple_element<I, array<T, N>> {
        static_assert(I < N, "array tuple_element index out of range");
        using type = T;
    };

    template <std::size_t I, class T, std::size_t N>
    [[nodiscard]]
    constexpr T& get(array<T, N>& a) noexcept {
        static_assert(I < N, "array get index out of range");
        return a[I];
    }

    template <std::size_t I, class T, std::size_t N>
    [[nodiscard]]
    constexpr const T& get(const array<T, N>& a) noexcept {
        static_assert(I < N, "array get index out of range");
        return a[I];
    }

    template <std::size_t I, class T, std::size_t N>
    [[nodiscard]]
    constexpr T&& get(array<T, N>&& a) noexcept {
        static_assert(I < N, "array get index out of range");
        return std::move(a[I]);
    }

    template <std::size_t I, class T, std::size_t N>
    [[nodiscard]]
    constexpr const T&& get(const array<T, N>&& a) noexcept {
        static_assert(I < N, "array get index out of range");
        return std::move(a[I]);
    }

    template <class T, std::size_t N>
    constexpr void swap(array<T, N>& lhs, array<T, N>& rhs) {
        lhs.swap(rhs);
    }

    template <class T, std::size_t N>
    [[nodiscard]]
    constexpr bool operator==(const array<T, N>& lhs,
                              const array<T, N>& rhs) {
        for (std::size_t i = 0; i < N; ++i) {
            if (!(lhs[i] == rhs[i])) {
                return false;
            }
        }
        return true;
    }

    template <class T, std::size_t N>
    [[nodiscard]]
    constexpr strong_ordering operator<=>(const array<T, N>& lhs,
                                          const array<T, N>& rhs) {
        for (std::size_t i = 0; i < N; ++i) {
            if (lhs[i] < rhs[i]) {
                return strong_ordering::less;
            }
            if (rhs[i] < lhs[i]) {
                return strong_ordering::greater;
            }
        }
        return strong_ordering::equivalent;
    }

    template <class T, std::size_t N>
    [[nodiscard]]
    constexpr bool operator!=(const array<T, N>& lhs,
                              const array<T, N>& rhs) {
        return !(lhs == rhs);
    }

    template <class T, std::size_t N>
    [[nodiscard]]
    constexpr bool operator<(const array<T, N>& lhs,
                             const array<T, N>& rhs) {
        return (lhs <=> rhs) < 0;
    }

    template <class T, std::size_t N>
    [[nodiscard]]
    constexpr bool operator<=(const array<T, N>& lhs,
                              const array<T, N>& rhs) {
        return (lhs <=> rhs) <= 0;
    }

    template <class T, std::size_t N>
    [[nodiscard]]
    constexpr bool operator>(const array<T, N>& lhs,
                             const array<T, N>& rhs) {
        return (lhs <=> rhs) > 0;
    }

    template <class T, std::size_t N>
    [[nodiscard]]
    constexpr bool operator>=(const array<T, N>& lhs,
                              const array<T, N>& rhs) {
        return (lhs <=> rhs) >= 0;
    }
}  // namespace std
