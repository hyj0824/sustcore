#pragma once

#include <compare>
#include <exception>
#include <functional>
#include <initializer_list>
#include <new>
#include <nt/errors.h>
#include <type_traits>
#include <utility>

namespace std {
    struct nullopt_t {
        explicit constexpr nullopt_t(int) noexcept {}
    };
    inline constexpr nullopt_t nullopt{0};

    struct in_place_t {
        explicit constexpr in_place_t() = default;
    };
    inline constexpr in_place_t in_place{};

    class bad_optional_access : public exception {
    public:
        constexpr bad_optional_access() noexcept = default;
        constexpr bad_optional_access(const bad_optional_access&) noexcept =
            default;
        constexpr bad_optional_access(bad_optional_access&&) noexcept = default;
        constexpr bad_optional_access& operator=(
            const bad_optional_access&) noexcept = default;
        constexpr bad_optional_access& operator=(
            bad_optional_access&&) noexcept = default;
        virtual ~bad_optional_access() noexcept override = default;

        [[nodiscard]]
        const char* what() const noexcept override {
            return "bad optional access";
        }
#ifdef __SUS_NO_RTTI__
        [[nodiscard]]
        const char* type() const override {
            return "std::bad_optional_access";
        }
#endif
    };

    template <class T>
    class optional {
    private:
        static_assert(!is_void_v<T>, "optional<T>: T 不应为空");
        static_assert(!is_reference_v<T>, "optional<T>: T 不应为引用");

        union __storage {
            char D_dummy;
            T D_value;

            constexpr __storage() : D_dummy() {}
            constexpr ~__storage() {}
        } D_storage;

        bool D_has_value = false;

        constexpr void U_destroy_active() noexcept {
            if (D_has_value) {
                D_storage.D_value.~T();
                D_has_value = false;
            }
        }

        template <class... Args>
        constexpr T& U_construct(Args&&... args) {
            new (&D_storage.D_value) T(std::forward<Args>(args)...);
            D_has_value = true;
            return D_storage.D_value;
        }

    public:
        using value_type = T;

        constexpr optional() noexcept = default;

        constexpr optional(nullopt_t) noexcept : optional() {}

        constexpr optional(const T& value) : optional() {
            U_construct(value);
        }

        constexpr optional(T&& value) : optional() {
            U_construct(std::move(value));
        }

        template <class... Args>
        constexpr explicit optional(in_place_t, Args&&... args) : optional() {
            U_construct(std::forward<Args>(args)...);
        }

        template <class U, class... Args>
        constexpr explicit optional(in_place_t, std::initializer_list<U> ilist,
                                    Args&&... args)
            : optional() {
            U_construct(ilist, std::forward<Args>(args)...);
        }

        constexpr optional(const optional& other) : optional() {
            if (other.D_has_value) {
                U_construct(other.D_storage.D_value);
            }
        }

        constexpr optional(optional&& other) : optional() {
            if (other.D_has_value) {
                U_construct(std::move(other.D_storage.D_value));
            }
        }

        constexpr ~optional() {
            U_destroy_active();
        }

        constexpr optional& operator=(nullopt_t) noexcept {
            reset();
            return *this;
        }

        constexpr optional& operator=(const optional& other) {
            if (this == &other) {
                return *this;
            }

            if (D_has_value && other.D_has_value) {
                D_storage.D_value = other.D_storage.D_value;
            } else if (D_has_value) {
                reset();
            } else if (other.D_has_value) {
                U_construct(other.D_storage.D_value);
            }
            return *this;
        }

        constexpr optional& operator=(optional&& other) {
            if (this == &other) {
                return *this;
            }

            if (D_has_value && other.D_has_value) {
                D_storage.D_value = std::move(other.D_storage.D_value);
            } else if (D_has_value) {
                reset();
            } else if (other.D_has_value) {
                U_construct(std::move(other.D_storage.D_value));
            }
            return *this;
        }

        constexpr optional& operator=(const T& value) {
            if (D_has_value) {
                D_storage.D_value = value;
            } else {
                U_construct(value);
            }
            return *this;
        }

        constexpr optional& operator=(T&& value) {
            if (D_has_value) {
                D_storage.D_value = std::move(value);
            } else {
                U_construct(std::move(value));
            }
            return *this;
        }

        [[nodiscard]]
        constexpr const T* operator->() const noexcept {
            return &D_storage.D_value;
        }

        [[nodiscard]]
        constexpr T* operator->() noexcept {
            return &D_storage.D_value;
        }

        [[nodiscard]]
        constexpr const T& operator*() const& noexcept {
            return D_storage.D_value;
        }

        [[nodiscard]]
        constexpr T& operator*() & noexcept {
            return D_storage.D_value;
        }

        [[nodiscard]]
        constexpr const T&& operator*() const&& noexcept {
            return std::move(D_storage.D_value);
        }

        [[nodiscard]]
        constexpr T&& operator*() && noexcept {
            return std::move(D_storage.D_value);
        }

        [[nodiscard]]
        constexpr explicit operator bool() const noexcept {
            return D_has_value;
        }

        [[nodiscard]]
        constexpr bool has_value() const noexcept {
            return D_has_value;
        }

        [[nodiscard]]
        EXCEPTION_DEPRECATED
        constexpr T& value() & {
            if (!D_has_value) {
                _THROW(bad_optional_access());
            }
            return D_storage.D_value;
        }

        [[nodiscard]]
        EXCEPTION_DEPRECATED
        constexpr const T& value() const& {
            if (!D_has_value) {
                _THROW(bad_optional_access());
            }
            return D_storage.D_value;
        }

        [[nodiscard]]
        EXCEPTION_DEPRECATED
        constexpr T&& value() && {
            if (!D_has_value) {
                _THROW(bad_optional_access());
            }
            return std::move(D_storage.D_value);
        }

        [[nodiscard]]
        EXCEPTION_DEPRECATED
        constexpr const T&& value() const&& {
            if (!D_has_value) {
                _THROW(bad_optional_access());
            }
            return std::move(D_storage.D_value);
        }

        [[nodiscard]]
        constexpr result_nt<T&> value_nt() & noexcept {
            if (!D_has_value) {
                return {unexpect, error_type::NULLPTR};
            }
            return std::ref(D_storage.D_value);
        }

        [[nodiscard]]
        constexpr result_nt<const T&> value_nt() const& noexcept {
            if (!D_has_value) {
                return {unexpect, error_type::NULLPTR};
            }
            return std::cref(D_storage.D_value);
        }

        [[nodiscard]]
        constexpr result_nt<T> value_nt() && noexcept {
            if (!D_has_value) {
                return {unexpect, error_type::NULLPTR};
            }
            return std::move(D_storage.D_value);
        }

        [[nodiscard]]
        constexpr result_nt<T> value_nt() const&& noexcept {
            if (!D_has_value) {
                return {unexpect, error_type::NULLPTR};
            }
            return D_storage.D_value;
        }

        template <class U>
        [[nodiscard]]
        constexpr T value_or(U&& default_value) const& {
            if (D_has_value) {
                return D_storage.D_value;
            }
            return static_cast<T>(std::forward<U>(default_value));
        }

        template <class U>
        [[nodiscard]]
        constexpr T value_or(U&& default_value) && {
            if (D_has_value) {
                return std::move(D_storage.D_value);
            }
            return static_cast<T>(std::forward<U>(default_value));
        }

        constexpr void reset() noexcept {
            U_destroy_active();
        }

        template <class... Args>
        constexpr T& emplace(Args&&... args) {
            reset();
            return U_construct(std::forward<Args>(args)...);
        }

        template <class U, class... Args>
        constexpr T& emplace(std::initializer_list<U> ilist, Args&&... args) {
            reset();
            return U_construct(ilist, std::forward<Args>(args)...);
        }

        constexpr void swap(optional& other) {
            optional tmp(std::move(other));
            other = std::move(*this);
            *this = std::move(tmp);
        }

        template <class F>
        constexpr auto and_then(F&& func) & {
            using result_type =
                decay_t<decltype(std::forward<F>(func)(D_storage.D_value))>;
            if (D_has_value) {
                return result_type(std::forward<F>(func)(D_storage.D_value));
            }
            return result_type(nullopt);
        }

        template <class F>
        constexpr auto and_then(F&& func) const& {
            using result_type =
                decay_t<decltype(std::forward<F>(func)(D_storage.D_value))>;
            if (D_has_value) {
                return result_type(std::forward<F>(func)(D_storage.D_value));
            }
            return result_type(nullopt);
        }

        template <class F>
        constexpr auto and_then(F&& func) && {
            using result_type = decay_t<decltype(
                std::forward<F>(func)(std::move(D_storage.D_value)))>;
            if (D_has_value) {
                return result_type(
                    std::forward<F>(func)(std::move(D_storage.D_value)));
            }
            return result_type(nullopt);
        }

        template <class F>
        constexpr auto and_then(F&& func) const&& {
            using result_type = decay_t<decltype(
                std::forward<F>(func)(std::move(D_storage.D_value)))>;
            if (D_has_value) {
                return result_type(
                    std::forward<F>(func)(std::move(D_storage.D_value)));
            }
            return result_type(nullopt);
        }

        template <class F>
        constexpr auto transform(F&& func) & {
            using result_type =
                decay_t<decltype(std::forward<F>(func)(D_storage.D_value))>;
            if (D_has_value) {
                return optional<result_type>(
                    std::forward<F>(func)(D_storage.D_value));
            }
            return optional<result_type>(nullopt);
        }

        template <class F>
        constexpr auto transform(F&& func) const& {
            using result_type =
                decay_t<decltype(std::forward<F>(func)(D_storage.D_value))>;
            if (D_has_value) {
                return optional<result_type>(
                    std::forward<F>(func)(D_storage.D_value));
            }
            return optional<result_type>(nullopt);
        }

        template <class F>
        constexpr auto transform(F&& func) && {
            using result_type = decay_t<decltype(
                std::forward<F>(func)(std::move(D_storage.D_value)))>;
            if (D_has_value) {
                return optional<result_type>(
                    std::forward<F>(func)(std::move(D_storage.D_value)));
            }
            return optional<result_type>(nullopt);
        }

        template <class F>
        constexpr auto transform(F&& func) const&& {
            using result_type = decay_t<decltype(
                std::forward<F>(func)(std::move(D_storage.D_value)))>;
            if (D_has_value) {
                return optional<result_type>(
                    std::forward<F>(func)(std::move(D_storage.D_value)));
            }
            return optional<result_type>(nullopt);
        }

        template <class F>
        constexpr optional or_else(F&& func) const& {
            if (D_has_value) {
                return *this;
            }
            return optional(std::forward<F>(func)());
        }

        template <class F>
        constexpr optional or_else(F&& func) && {
            if (D_has_value) {
                return std::move(*this);
            }
            return optional(std::forward<F>(func)());
        }
    };

    template <class T>
    optional(T) -> optional<T>;

    template <class T>
    constexpr void swap(optional<T>& lhs, optional<T>& rhs) {
        lhs.swap(rhs);
    }

    template <class T>
    [[nodiscard]]
    constexpr bool operator==(const optional<T>& lhs,
                              const optional<T>& rhs) {
        if (lhs.has_value() != rhs.has_value()) {
            return false;
        }
        if (!lhs.has_value()) {
            return true;
        }
        return *lhs == *rhs;
    }

    template <class T>
    [[nodiscard]]
    constexpr bool operator!=(const optional<T>& lhs,
                              const optional<T>& rhs) {
        return !(lhs == rhs);
    }

    template <class T>
    [[nodiscard]]
    constexpr bool operator<(const optional<T>& lhs, const optional<T>& rhs) {
        if (!rhs.has_value()) {
            return false;
        }
        if (!lhs.has_value()) {
            return true;
        }
        return *lhs < *rhs;
    }

    template <class T>
    [[nodiscard]]
    constexpr bool operator<=(const optional<T>& lhs, const optional<T>& rhs) {
        return !(rhs < lhs);
    }

    template <class T>
    [[nodiscard]]
    constexpr bool operator>(const optional<T>& lhs, const optional<T>& rhs) {
        return rhs < lhs;
    }

    template <class T>
    [[nodiscard]]
    constexpr bool operator>=(const optional<T>& lhs, const optional<T>& rhs) {
        return !(lhs < rhs);
    }

    template <class T>
    [[nodiscard]]
    constexpr strong_ordering operator<=>(const optional<T>& lhs,
                                          const optional<T>& rhs) {
        if (lhs < rhs) {
            return strong_ordering::less;
        }
        if (rhs < lhs) {
            return strong_ordering::greater;
        }
        return strong_ordering::equivalent;
    }

    template <class T>
    [[nodiscard]]
    constexpr bool operator==(const optional<T>& opt, nullopt_t) noexcept {
        return !opt.has_value();
    }

    template <class T>
    [[nodiscard]]
    constexpr bool operator==(nullopt_t, const optional<T>& opt) noexcept {
        return !opt.has_value();
    }

    template <class T>
    [[nodiscard]]
    constexpr bool operator!=(const optional<T>& opt, nullopt_t) noexcept {
        return opt.has_value();
    }

    template <class T>
    [[nodiscard]]
    constexpr bool operator!=(nullopt_t, const optional<T>& opt) noexcept {
        return opt.has_value();
    }

    template <class T>
    [[nodiscard]]
    constexpr bool operator<(const optional<T>&, nullopt_t) noexcept {
        return false;
    }

    template <class T>
    [[nodiscard]]
    constexpr bool operator<(nullopt_t, const optional<T>& opt) noexcept {
        return opt.has_value();
    }

    template <class T>
    [[nodiscard]]
    constexpr bool operator<=(const optional<T>& opt, nullopt_t) noexcept {
        return !opt.has_value();
    }

    template <class T>
    [[nodiscard]]
    constexpr bool operator<=(nullopt_t, const optional<T>&) noexcept {
        return true;
    }

    template <class T>
    [[nodiscard]]
    constexpr bool operator>(const optional<T>& opt, nullopt_t) noexcept {
        return opt.has_value();
    }

    template <class T>
    [[nodiscard]]
    constexpr bool operator>(nullopt_t, const optional<T>&) noexcept {
        return false;
    }

    template <class T>
    [[nodiscard]]
    constexpr bool operator>=(const optional<T>&, nullopt_t) noexcept {
        return true;
    }

    template <class T>
    [[nodiscard]]
    constexpr bool operator>=(nullopt_t, const optional<T>& opt) noexcept {
        return !opt.has_value();
    }

    template <class T>
    [[nodiscard]]
    constexpr strong_ordering operator<=>(const optional<T>& opt,
                                          nullopt_t) noexcept {
        return opt.has_value() ? strong_ordering::greater
                               : strong_ordering::equivalent;
    }

    template <class T>
    [[nodiscard]]
    constexpr strong_ordering operator<=>(nullopt_t,
                                          const optional<T>& opt) noexcept {
        return opt.has_value() ? strong_ordering::less
                               : strong_ordering::equivalent;
    }

    template <class T, class U>
    [[nodiscard]]
    constexpr bool operator==(const optional<T>& opt, const U& value) {
        return opt.has_value() && *opt == value;
    }

    template <class T, class U>
    [[nodiscard]]
    constexpr bool operator==(const U& value, const optional<T>& opt) {
        return opt.has_value() && value == *opt;
    }

    template <class T, class U>
    [[nodiscard]]
    constexpr bool operator!=(const optional<T>& opt, const U& value) {
        return !(opt == value);
    }

    template <class T, class U>
    [[nodiscard]]
    constexpr bool operator!=(const U& value, const optional<T>& opt) {
        return !(value == opt);
    }

    template <class T, class U>
    [[nodiscard]]
    constexpr bool operator<(const optional<T>& opt, const U& value) {
        return !opt.has_value() || *opt < value;
    }

    template <class T, class U>
    [[nodiscard]]
    constexpr bool operator<(const U& value, const optional<T>& opt) {
        return opt.has_value() && value < *opt;
    }

    template <class T, class U>
    [[nodiscard]]
    constexpr bool operator<=(const optional<T>& opt, const U& value) {
        return !opt.has_value() || *opt <= value;
    }

    template <class T, class U>
    [[nodiscard]]
    constexpr bool operator<=(const U& value, const optional<T>& opt) {
        return opt.has_value() && value <= *opt;
    }

    template <class T, class U>
    [[nodiscard]]
    constexpr bool operator>(const optional<T>& opt, const U& value) {
        return opt.has_value() && *opt > value;
    }

    template <class T, class U>
    [[nodiscard]]
    constexpr bool operator>(const U& value, const optional<T>& opt) {
        return !opt.has_value() || value > *opt;
    }

    template <class T, class U>
    [[nodiscard]]
    constexpr bool operator>=(const optional<T>& opt, const U& value) {
        return opt.has_value() && *opt >= value;
    }

    template <class T, class U>
    [[nodiscard]]
    constexpr bool operator>=(const U& value, const optional<T>& opt) {
        return !opt.has_value() || value >= *opt;
    }
}  // namespace std
