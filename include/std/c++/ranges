namespace std::ranges {
    namespace __cust {
        template <class T>
        constexpr T* __decay_copy(T* value) noexcept {
            return value;
        }

        struct __begin {
            template <class T, size_t N>
            [[nodiscard]]
            constexpr T* operator()(T (&arr)[N]) const noexcept {
                return arr;
            }

            template <class R>
                requires requires(R&& r) { std::forward<R>(r).begin(); }
            [[nodiscard]]
            constexpr auto operator()(R&& r) const
                noexcept(noexcept(std::forward<R>(r).begin())) {
                return std::forward<R>(r).begin();
            }
        };

        struct __end {
            template <class T, size_t N>
            [[nodiscard]]
            constexpr T* operator()(T (&arr)[N]) const noexcept {
                return arr + N;
            }

            template <class R>
                requires requires(R&& r) { std::forward<R>(r).end(); }
            [[nodiscard]]
            constexpr auto operator()(R&& r) const
                noexcept(noexcept(std::forward<R>(r).end())) {
                return std::forward<R>(r).end();
            }
        };
    }  // namespace __cust

    inline constexpr __cust::__begin begin{};
    inline constexpr __cust::__end end{};

    template <class T>
    concept range = requires(T& t) {
        ranges::begin(t);
        ranges::end(t);
    };

    template <class T>
    concept input_range = range<T>;

    template <range R>
    using iterator_t = decltype(ranges::begin(std::declval<R&>()));

    template <range R>
    using sentinel_t = decltype(ranges::end(std::declval<R&>()));

    template <range R>
    using range_reference_t = decltype(*ranges::begin(std::declval<R&>()));

    template <range R>
    using range_value_t =
        typename std::iterator_traits<iterator_t<R>>::value_type;

    template <range R>
    using range_difference_t =
        typename std::iterator_traits<iterator_t<R>>::difference_type;

    namespace __cust {
        struct __cbegin {
            template <class R>
            [[nodiscard]]
            constexpr auto operator()(const R& r) const
                noexcept(noexcept(ranges::begin(r))) {
                return ranges::begin(r);
            }
        };

        struct __cend {
            template <class R>
            [[nodiscard]]
            constexpr auto operator()(const R& r) const
                noexcept(noexcept(ranges::end(r))) {
                return ranges::end(r);
            }
        };

        struct __empty {
            template <class R>
                requires requires(R&& r) { std::forward<R>(r).empty(); }
            [[nodiscard]]
            constexpr bool operator()(R&& r) const noexcept(
                noexcept(static_cast<bool>(std::forward<R>(r).empty()))) {
                return static_cast<bool>(std::forward<R>(r).empty());
            }

            template <class T, size_t N>
            [[nodiscard]]
            constexpr bool operator()(T (&)[N]) const noexcept {
                return N == 0;
            }

            template <class R>
                requires(!requires(R&& r) { std::forward<R>(r).empty(); }) &&
                        requires(R&& r) { ranges::begin(r) == ranges::end(r); }
            [[nodiscard]]
            constexpr bool operator()(R&& r) const
                noexcept(noexcept(ranges::begin(r) == ranges::end(r))) {
                return ranges::begin(r) == ranges::end(r);
            }
        };

        struct __size {
            template <class R>
                requires requires(R&& r) { std::forward<R>(r).size(); }
            [[nodiscard]]
            constexpr auto operator()(R&& r) const
                noexcept(noexcept(std::forward<R>(r).size())) {
                return std::forward<R>(r).size();
            }

            template <class T, size_t N>
            [[nodiscard]]
            constexpr size_t operator()(T (&)[N]) const noexcept {
                return N;
            }

            template <class R>
                requires(!requires(R&& r) { std::forward<R>(r).size(); }) &&
                        requires(R&& r) { ranges::end(r) - ranges::begin(r); }
            [[nodiscard]]
            constexpr auto operator()(R&& r) const
                noexcept(noexcept(ranges::end(r) - ranges::begin(r))) {
                return ranges::end(r) - ranges::begin(r);
            }
        };

        struct __data {
            template <class R>
                requires requires(R&& r) { std::forward<R>(r).data(); }
            [[nodiscard]]
            constexpr auto operator()(R&& r) const
                noexcept(noexcept(std::forward<R>(r).data())) {
                return std::forward<R>(r).data();
            }

            template <class T, size_t N>
            [[nodiscard]]
            constexpr T* operator()(T (&arr)[N]) const noexcept {
                return arr;
            }

            template <class R>
                requires(!requires(R&& r) { std::forward<R>(r).data(); }) &&
                        requires(R&& r) { &*ranges::begin(r); }
            [[nodiscard]]
            constexpr auto operator()(R&& r) const
                noexcept(noexcept(&*ranges::begin(r))) {
                return &*ranges::begin(r);
            }
        };
    }  // namespace __cust

    inline constexpr __cust::__cbegin cbegin{};
    inline constexpr __cust::__cend cend{};
    inline constexpr __cust::__empty empty{};
    inline constexpr __cust::__size size{};
    inline constexpr __cust::__data data{};

    namespace __algo {
        struct __identity {
            template <class T>
            [[nodiscard]]
            constexpr T&& operator()(T&& value) const noexcept {
                return std::forward<T>(value);
            }
        };

        struct __less {
            template <class L, class R>
            [[nodiscard]]
            constexpr bool operator()(L&& lhs, R&& rhs) const {
                return std::forward<L>(lhs) < std::forward<R>(rhs);
            }
        };

        struct __equal_to {
            template <class L, class R>
            [[nodiscard]]
            constexpr bool operator()(L&& lhs, R&& rhs) const {
                return std::forward<L>(lhs) == std::forward<R>(rhs);
            }
        };

        struct __sort {
            template <class I, class S, class Comp = __less>
                requires(!range<I>)
            constexpr I operator()(I first, S last, Comp comp = {}) const {
                std::sort(first, last, comp);
                return first;
            }

            template <input_range R, class Comp = __less>
            constexpr iterator_t<R> operator()(R&& r, Comp comp = {}) const {
                return (*this)(ranges::begin(r), ranges::end(r), comp);
            }
        };

        struct __find {
            template <class I, class S, class T, class Proj = __identity>
                requires(!range<I>)
            [[nodiscard]]
            constexpr I operator()(I first, S last, const T& value,
                                   Proj proj = {}) const {
                while (first != last) {
                    if (std::invoke(proj, *first) == value) {
                        return first;
                    }
                    ++first;
                }
                return first;
            }

            template <input_range R, class T, class Proj = __identity>
            [[nodiscard]]
            constexpr iterator_t<R> operator()(R&& r, const T& value,
                                               Proj proj = {}) const {
                return (*this)(ranges::begin(r), ranges::end(r), value, proj);
            }
        };

        struct __contains {
            template <class I, class S, class T, class Proj = __identity>
                requires(!range<I>)
            [[nodiscard]]
            constexpr bool operator()(I first, S last, const T& value,
                                      Proj proj = {}) const {
                while (first != last) {
                    if (std::invoke(proj, *first) == value) {
                        return true;
                    }
                    ++first;
                }
                return false;
            }

            template <input_range R, class T, class Proj = __identity>
            [[nodiscard]]
            constexpr bool operator()(R&& r, const T& value,
                                      Proj proj = {}) const {
                return (*this)(ranges::begin(r), ranges::end(r), value, proj);
            }
        };

        struct __find_if {
            template <class I, class S, class Pred, class Proj = __identity>
                requires(!range<I>)
            [[nodiscard]]
            constexpr I operator()(I first, S last, Pred pred,
                                   Proj proj = {}) const {
                while (first != last) {
                    if (std::invoke(pred, std::invoke(proj, *first))) {
                        return first;
                    }
                    ++first;
                }
                return first;
            }

            template <input_range R, class Pred, class Proj = __identity>
            [[nodiscard]]
            constexpr iterator_t<R> operator()(R&& r, Pred pred,
                                               Proj proj = {}) const {
                return (*this)(ranges::begin(r), ranges::end(r), pred, proj);
            }
        };

        struct __remove_if {
            template <class I, class S, class Pred, class Proj = __identity>
                requires(!range<I>)
            constexpr I operator()(I first, S last, Pred pred,
                                   Proj proj = {}) const {
                I write = first;
                while (first != last) {
                    if (!std::invoke(pred, std::invoke(proj, *first))) {
                        *write = std::move(*first);
                        ++write;
                    }
                    ++first;
                }
                return write;
            }

            template <input_range R, class Pred, class Proj = __identity>
            constexpr iterator_t<R> operator()(R&& r, Pred pred,
                                               Proj proj = {}) const {
                return (*this)(ranges::begin(r), ranges::end(r), pred, proj);
            }
        };

        struct __remove {
            template <class I, class S, class T, class Proj = __identity>
                requires(!range<I>)
            constexpr I operator()(I first, S last, const T& value,
                                   Proj proj = {}) const {
                return __remove_if{}(
                    first, last,
                    [&value](const auto& elem) { return elem == value; }, proj);
            }

            template <input_range R, class T, class Proj = __identity>
            constexpr iterator_t<R> operator()(R&& r, const T& value,
                                               Proj proj = {}) const {
                return (*this)(ranges::begin(r), ranges::end(r), value, proj);
            }
        };

        struct __unique {
            template <class I, class S, class Pred = __equal_to,
                      class Proj = __identity>
                requires(!range<I>)
            constexpr I operator()(I first, S last, Pred pred = {},
                                   Proj proj = {}) const {
                if (first == last) {
                    return first;
                }

                I result = first;
                while (++first != last) {
                    if (!std::invoke(pred, std::invoke(proj, *result),
                                     std::invoke(proj, *first)))
                    {
                        ++result;
                        *result = std::move(*first);
                    }
                }
                ++result;
                return result;
            }

            template <input_range R, class Pred = __equal_to,
                      class Proj = __identity>
            constexpr iterator_t<R> operator()(R&& r, Pred pred = {},
                                               Proj proj = {}) const {
                return (*this)(ranges::begin(r), ranges::end(r), pred, proj);
            }
        };

        struct __reverse {
            template <class I, class S>
                requires(!range<I>)
            constexpr I operator()(I first, S last) const {
                if (first == last) {
                    return first;
                }

                for (;;) {
                    --last;
                    if (first == last) {
                        break;
                    }

                    auto tmp = std::move(*first);
                    *first   = std::move(*last);
                    *last    = std::move(tmp);
                    ++first;

                    if (first == last) {
                        break;
                    }
                }

                return first;
            }

            template <input_range R>
            constexpr iterator_t<R> operator()(R&& r) const {
                return (*this)(ranges::begin(r), ranges::end(r));
            }
        };

        struct __min {
            template <class T, class Comp = __less, class Proj = __identity>
            [[nodiscard]]
            constexpr const T& operator()(const T& a, const T& b,
                                          Comp comp = {},
                                          Proj proj = {}) const {
                return std::invoke(comp, std::invoke(proj, a),
                                   std::invoke(proj, b))
                           ? a
                           : b;
            }
        };

        struct __max {
            template <class T, class Comp = __less, class Proj = __identity>
            [[nodiscard]]
            constexpr const T& operator()(const T& a, const T& b,
                                          Comp comp = {},
                                          Proj proj = {}) const {
                return std::invoke(comp, std::invoke(proj, b),
                                   std::invoke(proj, a))
                           ? a
                           : b;
            }
        };

        struct __abs {
            template <class T>
            [[nodiscard]]
            constexpr T operator()(const T& value) const {
                return (value < 0) ? -value : value;
            }
        };

        struct __clamp {
            template <class T, class Comp = __less, class Proj = __identity>
            [[nodiscard]]
            constexpr T operator()(const T& value, const T& low, const T& high,
                                   Comp comp = {}, Proj proj = {}) const {
                if (std::invoke(comp, std::invoke(proj, value),
                                std::invoke(proj, low)))
                {
                    return low;
                }
                if (std::invoke(comp, std::invoke(proj, high),
                                std::invoke(proj, value)))
                {
                    return high;
                }
                return value;
            }
        };
    }  // namespace __algo

