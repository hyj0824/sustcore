    template <range R>
    using range_size_t = decltype(ranges::size(std::declval<R&>()));

    template <class T>
    inline constexpr bool enable_view = false;

    template <class T>
    concept view = range<T> && enable_view<remove_cvref_t<T>>;

    template <class T>
    concept borrowed_range = range<T>;

    template <class D>
    class view_interface {
    private:
        [[nodiscard]]
        constexpr D& U_derived() noexcept {
            return static_cast<D&>(*this);
        }

        [[nodiscard]]
        constexpr const D& U_derived() const noexcept {
            return static_cast<const D&>(*this);
        }

    public:
        [[nodiscard]]
        constexpr bool empty() {
            return ranges::begin(U_derived()) == ranges::end(U_derived());
        }

        [[nodiscard]]
        constexpr bool empty() const {
            return ranges::begin(U_derived()) == ranges::end(U_derived());
        }

        [[nodiscard]]
        constexpr auto front() {
            return *ranges::begin(U_derived());
        }

        [[nodiscard]]
        constexpr auto front() const {
            return *ranges::begin(U_derived());
        }

        [[nodiscard]]
        constexpr auto back() {
            auto last = ranges::end(U_derived());
            --last;
            return *last;
        }

        [[nodiscard]]
        constexpr auto back() const {
            auto last = ranges::end(U_derived());
            --last;
            return *last;
        }

        [[nodiscard]]
        constexpr auto operator[](ptrdiff_t n) {
            return ranges::begin(U_derived())[n];
        }

        [[nodiscard]]
        constexpr auto operator[](ptrdiff_t n) const {
            return ranges::begin(U_derived())[n];
        }
    };

    template <range R>
    class ref_view : public view_interface<ref_view<R>> {
    private:
        R* D_range = nullptr;

    public:
        constexpr ref_view() noexcept = default;
        constexpr explicit ref_view(R& r) noexcept : D_range(&r) {}

        [[nodiscard]]
        constexpr auto begin() const {
            return ranges::begin(*D_range);
        }

        [[nodiscard]]
        constexpr auto end() const {
            return ranges::end(*D_range);
        }

        [[nodiscard]]
        constexpr bool empty() const {
            return ranges::empty(*D_range);
        }

        [[nodiscard]]
        constexpr auto size() const {
            return ranges::size(*D_range);
        }

        [[nodiscard]]
        constexpr auto data() const {
            return ranges::data(*D_range);
        }
    };

    template <class R>
    inline constexpr bool enable_view<ref_view<R>> = true;

    template <range R>
    class owning_view : public view_interface<owning_view<R>> {
    private:
        R D_range;

    public:
        constexpr owning_view() = default;
        constexpr explicit owning_view(R&& r) : D_range(std::move(r)) {}

        [[nodiscard]]
        constexpr auto begin() {
            return ranges::begin(D_range);
        }

        [[nodiscard]]
        constexpr auto begin() const {
            return ranges::begin(D_range);
        }

        [[nodiscard]]
        constexpr auto end() {
            return ranges::end(D_range);
        }

        [[nodiscard]]
        constexpr auto end() const {
            return ranges::end(D_range);
        }

        [[nodiscard]]
        constexpr bool empty() const {
            return ranges::empty(D_range);
        }

        [[nodiscard]]
        constexpr auto size() const {
            return ranges::size(D_range);
        }

        [[nodiscard]]
        constexpr auto data() {
            return ranges::data(D_range);
        }

        [[nodiscard]]
        constexpr auto data() const {
            return ranges::data(D_range);
        }
    };

    template <class R>
    inline constexpr bool enable_view<owning_view<R>> = true;

    template <class I, class S = I>
    class subrange : public view_interface<subrange<I, S>> {
    private:
        I D_begin{};
        S D_end{};

    public:
        constexpr subrange() = default;
        constexpr subrange(I first, S last) : D_begin(first), D_end(last) {}

        [[nodiscard]]
        constexpr I begin() const {
            return D_begin;
        }

        [[nodiscard]]
        constexpr S end() const {
            return D_end;
        }

        [[nodiscard]]
        constexpr bool empty() const {
            return D_begin == D_end;
        }
    };

    template <class I, class S>
    inline constexpr bool enable_view<subrange<I, S>> = true;
}  // namespace std::ranges

namespace std::views {
    namespace __detail {
        template <class T>
        struct __is_lvalue_reference : false_type{};

        template <class T>
        struct __is_lvalue_reference<T&> : true_type{};

        template <class T>
        inline constexpr bool __is_lvalue_reference_v =
            __is_lvalue_reference<T>::value;

        struct __all {
            template <std::ranges::view R>
            [[nodiscard]]
            constexpr auto operator()(R&& r) const {
                return std::forward<R>(r);
            }

            template <std::ranges::range R>
                requires((!std::ranges::view<remove_cvref_t<R>>) &&
                         __is_lvalue_reference_v<R>)
            [[nodiscard]]
            constexpr auto operator()(R&& r) const {
                return std::ranges::ref_view<remove_reference_t<R>>(r);
            }

            template <std::ranges::range R>
                requires((!std::ranges::view<remove_cvref_t<R>>) &&
                         (!__is_lvalue_reference_v<R>))
            [[nodiscard]]
            constexpr auto operator()(R&& r) const {
                return std::ranges::owning_view<remove_cvref_t<R>>(
                    std::forward<R>(r));
            }
        };

        struct __counted {
            template <class I>
            [[nodiscard]]
            constexpr auto operator()(I first, std::ptrdiff_t count) const {
                return std::ranges::subrange<I, I>(first, first + count);
            }
        };
    }  // namespace __detail

    inline constexpr __detail::__all all{};
    inline constexpr __detail::__counted counted{};
}  // namespace std::views

